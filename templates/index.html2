<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Music Player</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .glass { background: rgba(17, 24, 39, 0.95); backdrop-filter: blur(10px); }
        .mini-player { position: fixed; bottom: 0; left: 0; right: 0; transition: all 0.3s ease; }
    </style>
</head>
<body class="bg-black text-white">

    <div class="max-w-4xl mx-auto p-4 pb-32">
        <header class="py-10 text-center">
            <h1 class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-600">
                Music Search
            </h1>
        </header>

        <div class="sticky top-4 z-10 mb-8">
            <div class="flex gap-2 p-2 bg-gray-900 border border-gray-800 rounded-full shadow-2xl">
                <input type="text" id="query" class="flex-1 bg-transparent px-4 outline-none" placeholder="Search song, artist...">
                <button onclick="search()" class="bg-blue-600 hover:bg-blue-700 px-6 py-2 rounded-full font-medium transition">Search</button>
            </div>
        </div>

        <div id="loader" class="hidden text-center py-10">Searching...</div>
        <div id="results" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6"></div>
    </div>

    <div id="playerUI" class="mini-player glass border-t border-gray-800 p-4 hidden">
        <div class="max-w-4xl mx-auto flex items-center gap-4">
            <img id="pImg" src="" class="w-14 h-14 rounded-lg shadow-lg">
            <div class="flex-1 overflow-hidden">
                <h3 id="pTitle" class="font-bold truncate"></h3>
                <p id="pArtist" class="text-sm text-gray-400 truncate"></p>
            </div>
            <audio id="mainAudio" controls class="w-full max-w-[200px] sm:max-w-md"></audio>
        </div>
    </div>

    <script>
        async function search() {
            const query = document.getElementById('query').value;
            if(!query) return;

            document.getElementById('loader').classList.remove('hidden');
            const res = await fetch(`/search?query=${query}`);
            const songs = await res.json();
            document.getElementById('loader').classList.add('hidden');

            const container = document.getElementById('results');
            container.innerHTML = "";

            songs.forEach(s => {
                const div = document.createElement('div');
                div.className = "group cursor-pointer bg-gray-900 p-3 rounded-xl hover:bg-gray-800 transition";
                div.onclick = () => play(s.song, s.singers, s.image, s.media_url);
                div.innerHTML = `
                    <div class="relative overflow-hidden rounded-lg mb-3">
                        <img src="${s.image}" class="w-full aspect-square object-cover transform group-hover:scale-105 transition">
                    </div>
                    <h4 class="font-bold truncate text-sm">${s.song}</h4>
                    <p class="text-xs text-gray-500 truncate">${s.singers}</p>
                `;
                container.appendChild(div);
            });
        }

        function play(title, artist, img, url) {
            if(!url) { alert("Song URL not found!"); return; }
            document.getElementById('playerUI').classList.remove('hidden');
            document.getElementById('pTitle').innerText = title;
            document.getElementById('pArtist').innerText = artist;
            document.getElementById('pImg').src = img;
            
            const audio = document.getElementById('mainAudio');
            audio.src = url;
            audio.play();
        }
    </script>
</body>
</html>
